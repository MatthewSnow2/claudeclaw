# ── Required ──────────────────────────────────────────────────────────────────

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID. Start the bot, send /chatid, paste the number here, restart.
ALLOWED_CHAT_ID=

# ── Optional (Auth Override) ───────────────────────────────────────────────────
# ClaudeClaw uses the Claude Code OAuth auth already on this Mac (your Max plan).
# Only set these if you need to override which account/key is used.

# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# ── Voice ─────────────────────────────────────────────────────────────────────
# Groq — free tier, for voice transcription (Whisper)
# Get at: https://console.groq.com
GROQ_API_KEY=

# ElevenLabs — for voice responses in Mark's cloned voice
# Get at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
